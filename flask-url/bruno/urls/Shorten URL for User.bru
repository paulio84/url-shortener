meta {
  name: Shorten URL for User
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/shorten
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "url": "https://www.amazon.co.uk/"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("lastShortCode", res.body.short_code);
  }
}
